getboot:
  governance:
    enabled: true
    sentinel:
      enabled: true
      eager: false
      web-context-unify: true
      http-method-specify: false
      block-page: /blocked.html
      transport:
        dashboard: 127.0.0.1:8858
        port: 8719
      filter:
        enabled: true
        order: -2147483648
      openfeign:
        enabled: true
      rest-template:
        enabled: true
      gateway:
        order: -1
        fallback:
          mode: response
          response-status: 429
          response-body: '{"status":"fail","code":429,"message":"Too many requests"}'
          content-type: application/json;charset=UTF-8
      management:
        endpoint:
          enabled: true
        health:
          enabled: true
