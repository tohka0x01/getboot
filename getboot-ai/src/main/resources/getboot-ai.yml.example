getboot:
  ai:
    enabled: true
    type: openai
    openai:
      enabled: true
      base-url: https://api.openai.com/v1
      api-key: sk-xxx
      organization:
      project:
      default-chat-model: gpt-5-mini
      default-embedding-model: text-embedding-3-small
      default-reasoning-effort: low
      connect-timeout: 3s
      read-timeout: 30s
      default-headers:
        X-Request-Source: getboot
